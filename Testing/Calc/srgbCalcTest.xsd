<?xml version="1.0" encoding="utf-8"?>
<xs:schema attributeFormDefault="unqualified" elementFormDefault="qualified" xmlns:xs="http://www.w3.org/2001/XMLSchema">
	<xs:element name="IccProfile">
		<xs:complexType>
			<xs:sequence>
				<xs:element name="Header">
					<xs:complexType>
						<xs:sequence>
							<xs:element name="PreferredCMMType" />
							<xs:element name="ProfileVersion" type="xs:decimal" />
							<xs:element name="ProfileDeviceClass" type="xs:string" />
							<xs:element name="DataColourSpace" type="xs:string" />
							<xs:element name="PCS" type="xs:string" />
							<xs:element name="CreationDateTime" type="xs:string" />
							<xs:element name="ProfileFlags">
								<xs:complexType>
									<xs:attribute name="EmbeddedInFile" type="xs:boolean" use="required" />
									<xs:attribute name="UseWithEmbeddedDataOnly" type="xs:boolean" use="required" />
								</xs:complexType>
							</xs:element>
							<xs:element name="DeviceAttributes">
								<xs:complexType>
									<xs:attribute name="ReflectiveOrTransparency" type="xs:string" use="required" />
									<xs:attribute name="GlossyOrMatte" type="xs:string" use="required" />
									<xs:attribute name="MediaPolarity" type="xs:string" use="required" />
									<xs:attribute name="MediaColour" type="xs:string" use="required" />
								</xs:complexType>
							</xs:element>
							<xs:element name="RenderingIntent" type="xs:string" />
							<xs:element name="PCSIlluminant">
								<xs:complexType>
									<xs:sequence>
										<xs:element name="XYZNumber">
											<xs:complexType>
												<xs:attribute name="X" type="xs:decimal" use="required" />
												<xs:attribute name="Y" type="xs:decimal" use="required" />
												<xs:attribute name="Z" type="xs:decimal" use="required" />
											</xs:complexType>
										</xs:element>
									</xs:sequence>
								</xs:complexType>
							</xs:element>
							<xs:element name="ProfileCreator" type="xs:string" />
							<xs:element name="ProfileID" type="xs:string" />
						</xs:sequence>
					</xs:complexType>
				</xs:element>
				<xs:element name="Tags">
					<xs:complexType>
						<xs:sequence>
							<xs:choice maxOccurs="unbounded">
								<xs:element name="multiLocalizedUnicodeType">
									<xs:complexType>
										<xs:sequence>
											<xs:element name="TagSignature" type="xs:string" />
											<xs:element name="LocalizedText">
												<xs:complexType>
													<xs:simpleContent>
														<xs:extension base="xs:string">
															<xs:attribute name="LanguageCountry" type="xs:string" use="required" />
														</xs:extension>
													</xs:simpleContent>
												</xs:complexType>
											</xs:element>
										</xs:sequence>
									</xs:complexType>
								</xs:element>
								<xs:element maxOccurs="unbounded" name="multiProcessElementType">
									<xs:complexType>
										<xs:sequence>
											<xs:element name="TagSignature" type="xs:string" />
											<xs:element name="MultiProcessElements">
												<xs:complexType>
													<xs:sequence>
														<xs:element minOccurs="0" name="MatrixElement">
															<xs:complexType>
																<xs:sequence>
																	<xs:element name="MatrixData" type="xs:string" />
																</xs:sequence>
																<xs:attribute name="InputChannels" type="xs:unsignedByte" use="required" />
																<xs:attribute name="OutputChannels" type="xs:unsignedByte" use="required" />
															</xs:complexType>
														</xs:element>
														<xs:element minOccurs="0" name="CurveSetElement">
															<xs:complexType>
																<xs:sequence>
																	<xs:element maxOccurs="unbounded" name="SegmentedCurve">
																		<xs:complexType>
																			<xs:sequence>
																				<xs:element maxOccurs="unbounded" name="FormulaSegment">
																					<xs:complexType>
																						<xs:simpleContent>
																							<xs:extension base="xs:string">
																								<xs:attribute name="Start" type="xs:string" use="required" />
																								<xs:attribute name="End" type="xs:string" use="required" />
																								<xs:attribute name="FunctionType" type="xs:unsignedByte" use="required" />
																							</xs:extension>
																						</xs:simpleContent>
																					</xs:complexType>
																				</xs:element>
																			</xs:sequence>
																		</xs:complexType>
																	</xs:element>
																</xs:sequence>
																<xs:attribute name="InputChannels" type="xs:unsignedByte" use="required" />
																<xs:attribute name="OutputChannels" type="xs:unsignedByte" use="required" />
															</xs:complexType>
														</xs:element>
														<xs:element minOccurs="0" name="CalculatorElement">
															<xs:complexType>
																<xs:sequence>
																	<xs:element name="SubElements">
																		<xs:complexType>
																			<xs:sequence>
																				<xs:element maxOccurs="unbounded" name="CurveSetElement">
																					<xs:complexType>
																						<xs:sequence>
																							<xs:element maxOccurs="unbounded" name="SegmentedCurve">
																								<xs:complexType>
																									<xs:sequence>
																										<xs:element maxOccurs="unbounded" name="FormulaSegment">
																											<xs:complexType>
																												<xs:simpleContent>
																													<xs:extension base="xs:string">
																														<xs:attribute name="Start" type="xs:string" use="required" />
																														<xs:attribute name="End" type="xs:string" use="required" />
																														<xs:attribute name="FunctionType" type="xs:unsignedByte" use="required" />
																													</xs:extension>
																												</xs:simpleContent>
																											</xs:complexType>
																										</xs:element>
																									</xs:sequence>
																								</xs:complexType>
																							</xs:element>
																						</xs:sequence>
																						<xs:attribute name="InputChannels" type="xs:unsignedByte" use="required" />
																						<xs:attribute name="OutputChannels" type="xs:unsignedByte" use="required" />
																					</xs:complexType>
																				</xs:element>
																				<xs:element maxOccurs="unbounded" name="MatrixElement">
																					<xs:complexType>
																						<xs:sequence>
																							<xs:element name="MatrixData" type="xs:string" />
																						</xs:sequence>
																						<xs:attribute name="InputChannels" type="xs:unsignedByte" use="required" />
																						<xs:attribute name="OutputChannels" type="xs:unsignedByte" use="required" />
																					</xs:complexType>
																				</xs:element>
																				<xs:element name="CLutElement">
																					<xs:complexType>
																						<xs:sequence>
																							<xs:element name="GridPoints" type="xs:string" />
																							<xs:element name="TableData" type="xs:string" />
																						</xs:sequence>
																						<xs:attribute name="InputChannels" type="xs:unsignedByte" use="required" />
																						<xs:attribute name="OutputChannels" type="xs:unsignedByte" use="required" />
																					</xs:complexType>
																				</xs:element>
																				<xs:element name="CalculatorElement">
																					<xs:complexType>
																						<xs:sequence>
																							<xs:element name="MainFunction" type="xs:string" />
																						</xs:sequence>
																						<xs:attribute name="InputChannels" type="xs:unsignedByte" use="required" />
																						<xs:attribute name="OutputChannels" type="xs:unsignedByte" use="required" />
																					</xs:complexType>
																				</xs:element>
																				<xs:element name="JabToXYZElement">
																					<xs:complexType>
																						<xs:sequence>
																							<xs:element name="ColorAppearanceParams">
																								<xs:complexType>
																									<xs:sequence>
																										<xs:element name="WhitePoint">
																											<xs:complexType>
																												<xs:sequence>
																													<xs:element name="XYZNumber">
																														<xs:complexType>
																															<xs:attribute name="X" type="xs:decimal" use="required" />
																															<xs:attribute name="Y" type="xs:decimal" use="required" />
																															<xs:attribute name="Z" type="xs:decimal" use="required" />
																														</xs:complexType>
																													</xs:element>
																												</xs:sequence>
																											</xs:complexType>
																										</xs:element>
																										<xs:element name="Luminance" type="xs:decimal" />
																										<xs:element name="BackgroundLuminance" type="xs:decimal" />
																										<xs:element name="ImpactSurround" type="xs:decimal" />
																										<xs:element name="ChromaticInductionFactor" type="xs:decimal" />
																										<xs:element name="AdaptationFactor" type="xs:decimal" />
																									</xs:sequence>
																								</xs:complexType>
																							</xs:element>
																						</xs:sequence>
																						<xs:attribute name="InputChannels" type="xs:unsignedByte" use="required" />
																						<xs:attribute name="OutputChannels" type="xs:unsignedByte" use="required" />
																					</xs:complexType>
																				</xs:element>
																				<xs:element name="XYZToJabElement">
																					<xs:complexType>
																						<xs:sequence>
																							<xs:element name="ColorAppearanceParams">
																								<xs:complexType>
																									<xs:sequence>
																										<xs:element name="WhitePoint">
																											<xs:complexType>
																												<xs:sequence>
																													<xs:element name="XYZNumber">
																														<xs:complexType>
																															<xs:attribute name="X" type="xs:decimal" use="required" />
																															<xs:attribute name="Y" type="xs:decimal" use="required" />
																															<xs:attribute name="Z" type="xs:decimal" use="required" />
																														</xs:complexType>
																													</xs:element>
																												</xs:sequence>
																											</xs:complexType>
																										</xs:element>
																										<xs:element name="Luminance" type="xs:decimal" />
																										<xs:element name="BackgroundLuminance" type="xs:decimal" />
																										<xs:element name="ImpactSurround" type="xs:decimal" />
																										<xs:element name="ChromaticInductionFactor" type="xs:decimal" />
																										<xs:element name="AdaptationFactor" type="xs:decimal" />
																									</xs:sequence>
																								</xs:complexType>
																							</xs:element>
																						</xs:sequence>
																						<xs:attribute name="InputChannels" type="xs:unsignedByte" use="required" />
																						<xs:attribute name="OutputChannels" type="xs:unsignedByte" use="required" />
																					</xs:complexType>
																				</xs:element>
																				<xs:element name="TintArrayElement">
																					<xs:complexType>
																						<xs:sequence>
																							<xs:element name="float32NumberType">
																								<xs:complexType>
																									<xs:sequence>
																										<xs:element name="Data" type="xs:string" />
																									</xs:sequence>
																								</xs:complexType>
																							</xs:element>
																						</xs:sequence>
																						<xs:attribute name="InputChannels" type="xs:unsignedByte" use="required" />
																						<xs:attribute name="OutputChannels" type="xs:unsignedByte" use="required" />
																					</xs:complexType>
																				</xs:element>
																			</xs:sequence>
																		</xs:complexType>
																	</xs:element>
																	<xs:element name="MainFunction" type="xs:string" />
																</xs:sequence>
																<xs:attribute name="InputChannels" type="xs:unsignedByte" use="required" />
																<xs:attribute name="OutputChannels" type="xs:unsignedByte" use="required" />
															</xs:complexType>
														</xs:element>
													</xs:sequence>
													<xs:attribute name="InputChannels" type="xs:unsignedByte" use="required" />
													<xs:attribute name="OutputChannels" type="xs:unsignedByte" use="required" />
												</xs:complexType>
											</xs:element>
										</xs:sequence>
									</xs:complexType>
								</xs:element>
								<xs:element name="XYZType">
									<xs:complexType>
										<xs:sequence>
											<xs:element name="TagSignature" type="xs:string" />
											<xs:element name="XYZNumber">
												<xs:complexType>
													<xs:attribute name="X" type="xs:decimal" use="required" />
													<xs:attribute name="Y" type="xs:decimal" use="required" />
													<xs:attribute name="Z" type="xs:decimal" use="required" />
												</xs:complexType>
											</xs:element>
										</xs:sequence>
									</xs:complexType>
								</xs:element>
							</xs:choice>
						</xs:sequence>
					</xs:complexType>
				</xs:element>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
</xs:schema>