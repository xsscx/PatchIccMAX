# ------------------------
# OS-generated files
# ------------------------
.DS_Store
Thumbs.db
ehthumbs.db

# ------------------------
# Compiled Object files
# ------------------------
*.slo
*.lo
*.o
*.obj

# ------------------------
# Precompiled Headers
# ------------------------
*.gch
*.pch

# ------------------------
# Compiled Dynamic libraries
# ------------------------
*.so
*.dylib
*.dll

# ------------------------
# Fortran module files
# ------------------------
*.mod

# ------------------------
# Compiled Static libraries
# ------------------------
*.lai
*.la
*.a
*.lib

# ------------------------
# Executables
# ------------------------
*.exe
*.out
*.app

# ------------------------
# Testing ICC profiles
# ------------------------
Testing/*/*.icc

# ------------------------
# Xcode-specific ignores
# ------------------------
**/*.noindex
**/Build
!/Build
**/xcuserdata
**/DerivedData
**/DataStore
**/.DS_Store

# ------------------------
# Visual Studio-specific ignores
# ------------------------
**/.vs
*.vcxproj.user
*.idb
*.pdb
*.exp
*.ilk
*.tlog
*.log
*.recipe

# Ignore build directories
**/Release/**
**/Debug/**
**/x64/**
**/Win32/**

# Ignore specific Visual Studio generated file
*.vcxproj.FileListAbsolute.txt

# ------------------------
# macOS Specific Ignored Files
# ------------------------

# macOS folder attributes
.DS_Store
.AppleDouble
.LSOverride

# macOS resource fork files
._*

# macOS Finder attributes
Icon?
._Icon?
.Spotlight-V100
.Trashes
.VolumeIcon.icns

# macOS Metadata
com.apple.timemachine.*
com.apple.sparsebundle.*

# macOS filesystem temp files
.TemporaryItems
.Trash-*
.fseventsd
.apdisk

# ------------------------
# Linux Specific Ignored Files
# ------------------------

# Temporary files created by editors
*~

# Temporary files created by the diff tool
*.orig

# Trash directory (if using KDE or GNOME)
.Trash-*

# Files generated by gnome-keyring-daemon
.keyring
*.desktop

# Directories generated by package managers
**/node_modules/
**/bower_components/
**/target/
**/dist/

# Backup files
*.bak
*.swp
*.swo
*.swx
*.tmp

# Lock files
*.lock

# ------------------------
# Windows Specific Ignored Files
# ------------------------

# Windows thumbnail cache files
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# Windows file system metadata
*.ini

# Windows Installer files
*.cab
*.msi
*.msm
*.msp

# Windows shortcuts
*.lnk

# Windows backup files
*.bak
*.swp
*.swo
*.swx
*.tmp
*.old

# Hidden files for sensitive data
*.secret
*.key

# Windows specific log files
*.log
*.eventlog

# Windows paging file
pagefile.sys
swapfile.sys

# Windows hibernation file
hiberfil.sys

# ------------------------
# Sensitive Information
# ------------------------

# Ignore environment variable files (commonly used for configuration)
.env
.env.*
.env.local
.env.production
.env.development

# Ignore JSON files that might store secrets
*.secret.json
*.key.json
*.token.json

# Ignore YAML files that might store secrets
*.secret.yaml
*.key.yaml
*.token.yaml

# Ignore configuration files that may store passwords or API keys
config.json
config.yaml
config.local.json
config.local.yaml

# Ignore specific sensitive files
secrets.yml
keys.yml
credentials.yml
private.key
public.key
*.pem

# Ignore temporary credential files generated by cloud services or CI/CD pipelines
.aws/credentials
.gcloud/
.kube/config
*.kubecfg
.terraform/

# ------------------------
# CMake-specific ignores
# ------------------------
CMakeLists.txt.user
CMakeCache.txt
CMakeFiles/
CMakeScripts/
Testing/
Makefile
cmake_install.cmake
install_manifest.txt
compile_commands.json
CTestTestfile.cmake
_deps/
CMakeUserPresets.json
